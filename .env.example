# Copy this file to `.env` in the project root and fill in your values.
# Docker Compose reads `.env` automatically when you run: docker compose up -d --build backend
#
# --- Local dev (default): Mailpit catches emails at http://localhost:8025 ---
# Leave Smtp__Host unset or set to mailpit — no Brevo needed.
#
# --- Brevo (real emails): uncomment and fill in the block below ---

# Smtp__Enabled=true
# Smtp__Host=smtp-relay.brevo.com
# Smtp__Port=587
# Smtp__EnableSsl=true
# Smtp__Username=ae218f001@smtp-brevo.com
# Smtp__Password=YOUR_BREVO_SMTP_KEY_HERE
# Smtp__From=osamaalhossam63@gmail.com
# App__FrontendUrl=http://localhost:5173

# For Vercel hosting, set to your deployment URL:
# App__FrontendUrl=https://your-app.vercel.app

# --- Database: Supabase Postgres (cloud) or local Docker Postgres ---
# Supabase → Project Settings → Database → connection string:
# ConnectionStrings__OmsDb=Host=db.xxxx.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=...;SSL Mode=Require;Trust Server Certificate=true;
#
# Local Docker (docker compose up):
# ConnectionStrings__OmsDb=Host=localhost;Port=5432;Database=oms;Username=postgres;Password=postgres;

# For Firebase hosting:
# App__FrontendUrl=https://alwakeel-alshamel.web.app
