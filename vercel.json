{
  "buildCommand": "npm ci --prefix frontend && npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://oms-api-23gt.onrender.com/api/:path*" },
    { "source": "/health", "destination": "https://oms-api-23gt.onrender.com/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
