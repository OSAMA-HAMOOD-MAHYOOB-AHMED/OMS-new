# Supabase Postgres connection for Render / local backend
# Get from: Supabase → Project Settings → Database → Connection string
#
# .NET / Npgsql format (Session pooler, port 5432):
# ConnectionStrings__OmsDb=Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;
#
# Or Transaction pooler (port 6543) — add:
# ;Pooling=true;Maximum Pool Size=5;

ConnectionStrings__OmsDb=Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;

App__FrontendUrl=https://frontend-three-omega-20.vercel.app

Smtp__Enabled=true
Smtp__Host=smtp-relay.brevo.com
Smtp__Port=587
Smtp__EnableSsl=true
Smtp__Username=your-brevo-username
Smtp__Password=your-brevo-smtp-key
Smtp__From=you@example.com
